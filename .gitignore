*
!.gitignore
!/README.md
!/CLAUDE.md
!/settings.json
!/setup.sh
!/statusline-command.sh
!/scripts/
!/scripts/**
!/commands/
!/commands/**
!/context/
!/context/**
!/skills/
!/skills/**
/skills/investigating-gcp-observability/
!/agents/
!/agents/**
!/hooks/
!/hooks/**
!/workflows/
!/workflows/**
!/scheduled-tasks/
!/scheduled-tasks/**
!/rules/
!/rules/**
!/templates/
!/templates/**
!/sui-memory/
!/sui-memory/**
# Exclude uv/Python artifacts in sui-memory
/sui-memory/.venv/
/sui-memory/uv.lock
/sui-memory/__pycache__/
/sui-memory/**/__pycache__/
/sui-memory/*.egg-info/
!/evals/
!/evals/**
# Exclude eval results runtime artifacts
/evals/reviewer/results/**/raw/
# Include plugin configuration
!/plugins/
!/plugins/installed_plugins.json
!/plugins/known_marketplaces.json
!/plugins/cursor/
!/plugins/cursor/**
# Exclude plugin caches and downloaded content
/plugins/cache/
/plugins/marketplaces/
/plugins/data/
/plugins/plugin-catalog-cache.json
/plugins/.last_inuse_sweep
